---
import BaseLayout from '../../../../layouts/BaseLayout.astro'
import EditingTitle from '../../../../components/EditingTitle.astro'
import NoJS from '../../../../components/NoJS.astro'
import WorldForm from '../../../../components/WorldForm.astro'
import { apiRoot, apiHeaders } from '../../../../data'
import getAuth from '../../../../utils/get-auth'
import redirect from '../../../../utils/redirect'

const { slug } = Astro.params
const auth = getAuth(Astro)
if (!auth?.apiKey) {
  return redirect(`/catalogue/worlds/${slug}`)
}

const { apiKey, username } = auth
let world: { [key: string]: any } | null = null
let isCreator = false
let ancestors: Array<{ path: string, name: string }> = []
let message = ''

if (apiKey === undefined) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: '/catalogue/worlds'
    },
  })
}

try {
  const res = await fetch(`${apiRoot}/worlds/${slug}`, {
    method: 'GET',
    headers: {
      ...apiHeaders,
      Authorization: `Bearer ${apiKey}`
    }
  })

  ancestors = [
    { path: '/catalogue', name: 'Catalogue' },
    { path: '/catalogue/worlds', name: 'Worlds' },
  ]

  if (res.status === 200) {
    world = await res.json()
    isCreator = world?.creators.map((creator: { [key: string]: any }) => creator.username).includes(username) ?? false
  }
} catch (err) {
  console.error(err)
}

if (!isCreator) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: `/catalogue/worlds/${slug}`,
    },
  })
}

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData()
    const name = formData.get('name')
    const newSlug = formData.get('slug')
    const creators = (formData.get('creators') as string).split(',').map(c => c.trim())
    const description = formData.get('description')
    const isPublic = formData.get('public') === 'on'

    const res = await fetch(`${apiRoot}/worlds/${slug}`, {
      method: 'PUT',
      headers: {
        ...apiHeaders,
        Authorization: `Bearer ${apiKey}`
      },
      body: JSON.stringify({ name, slug: newSlug, creators, description, public: isPublic })
    })

    const data = await res.json()
    if (res.status !== 200) {
      throw new Error(data.error)
    }

    return new Response(null, {
      status: 302,
      headers: {
        Location: `/catalogue/worlds/${data.slug}`,
      },
    })
  } catch (err) {
    message = 'Sorry, something went wrong. Please try again.'
    console.error(err)
  }
}
---
<BaseLayout title={world?.name ? `Editing ${world.name}` : 'Editing World'}>
  <EditingTitle name={world?.name} fallback="World" />
  {message && <aside class="message error">{message}</aside>}
  <WorldForm
    world={world}
    action={`/catalogue/worlds/${world?.slug}/edit`}
    button="Save"
    isEdit={true} />
  <NoJS />
</BaseLayout>
