---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { apiRoot, apiHeaders, defaultPageSize } from '../../../data'
import Pagination from '../../../components/Pagination.astro'
import SpeciesListing from '../../../components/SpeciesListing.astro'
import getAuth from '../../../utils/get-auth'

const { apiKey } = getAuth(Astro)
let data: { [key: string]: any } = {}

const pageParam = 'page'
const pageSizeParam = 'page_size'
const page = Astro.url.searchParams.get(pageParam) ?? 1
const pageSize = Astro.url.searchParams.get(pageSizeParam) ?? defaultPageSize
const url = `${apiRoot}/species?page=${page}&page_size=${pageSize}`

try {
  const res = await fetch(url, {
    method: 'GET',
    headers: {
      ...apiHeaders,
      Authorization: `Bearer ${apiKey}`
    }
  })

  data = await res.json()
} catch (err) {
  console.error(err)
}
---
<BaseLayout title="Species">
  <h1>Species</h1>
  {data.species && data.species.length > 0 && data.species.map(species => (
    <SpeciesListing species={species} context="index" />
  ))}
  {data.total > data.page_size && (<Pagination page={data} baseUrl="/catalogue/species" pageParam="page" pageSizeParam="page_size" />)}
</BaseLayout>
