---
import MarkdownContent from './MarkdownContent.astro'
import UserLinks from './UserLinks.astro'

const { world } = Astro.props
const slug = world.path.substring(8)
---
<article class="world card">
  <header>
    <h3>
      <a href={`/catalogue/worlds/${slug}`}>{world.name}</a>
    </h3>
    <p class="secondary">Created by <UserLinks users={world.creators} /></p>
  </header>
  <MarkdownContent tag="div" content={world.description}></MarkdownContent>
</article>
